# ─── SERVER ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────────
# Get from MongoDB Atlas → Create cluster → Connect → Driver
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/battlenix?retryWrites=true&w=majority

# ─── REDIS ────────────────────────────────────────────
# Local: redis://localhost:6379
# Production: Get from Railway or Upstash
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_change_in_production

# ─── RAZORPAY ─────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get from Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── SOCKET.IO ────────────────────────────────────────
# For Flutter: use your server's public URL
# For local dev: use *
SOCKET_CORS_ORIGIN=*
