            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Match\",\n  \"game\": \"BGMI\",\n  \"entryFee\": 50,\n  \"maxPlayers\": 2,\n  \"startTime\": \"2026-12-01T10:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/matches",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "matches"
              ]
            }
