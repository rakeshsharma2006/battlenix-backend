# SERVER
PORT=3000
NODE_ENV=development

# MONGODB
# Get from MongoDB Atlas -> Create cluster -> Connect -> Driver
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/battlenix?retryWrites=true&w=majority

# REDIS
# Local: redis://localhost:6379
# Production: Get from Railway or Upstash
REDIS_URL=redis://localhost:6379

# TOKENS
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_change_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production

# GOOGLE OAUTH
# Get from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client IDs
# Use the Web Client ID for server-side ID token verification.
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
MOBILE_GOOGLE_CALLBACK_URL=battlenix://auth/google/callback

# FRONTEND / CORS
# Required in production for browser clients.
FRONTEND_ORIGIN=https://your-frontend-domain.com

# RAZORPAY
# Get from Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Get from Razorpay Dashboard -> Settings -> Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SOCKET.IO
# For Flutter: use your server's public URL
# For local dev: use *
SOCKET_CORS_ORIGIN=*
