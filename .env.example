 
 

# ENVIRONMENT
NODE_ENV=production
LOG_LEVEL=info

# TOKENS
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your_access_token_secret_change_in_production
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production

# DATABASE
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net/battlenix
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# FRONTEND / CORS
# Required in production for browser clients.
FRONTEND_ORIGIN=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://battlenix-admin.vercel.app

 
 

# SOCKET.IO
# For Flutter: use your server's public URL
# For local dev: use *
SOCKET_CORS_ORIGIN=*

# REFERRAL SYSTEM
# Base URL for referral link generation (e.g. https://yourdomain.com)
REFERRAL_BASE_URL=https://yourdomain.com
# Where to redirect after referral click (APK download page or website)
APP_DOWNLOAD_URL=https://play.google.com/store/apps/details?id=com.battlenix
# Play Store package name (used for future Play Store deep-link referrals)
PLAYSTORE_PACKAGE=com.battlenix.app

# RAZORPAY
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_render_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_render_secret
